{
  "manifest_version": 3,
  "name": "Firehouse",
  "version": "2.0.0",
  "description": "Track your support time from a quick dropdown in your toolbar.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Firehouse",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://vicfnkbsrcmemhffuqyq.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  }
}
